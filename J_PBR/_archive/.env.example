# J-Quants credentials
# Choose ONE of the two options below.

# Option A (recommended): a long-lived refresh token from
# https://jpx-jquants.com/  -> "Refresh Token" tab
JQUANTS_REFRESH_TOKEN=

# Option B: mail + password (the script will exchange them for a refresh token).
JQUANTS_MAIL=
JQUANTS_PASSWORD=
